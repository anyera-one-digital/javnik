# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_DB=bookly_db
POSTGRES_USER=bookly_user
POSTGRES_PASSWORD=bookly_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===========================================
# Django Backend
# ===========================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,nginx,localhost:8765
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:8765,http://localhost:4000,http://127.0.0.1:8765,http://127.0.0.1:4000

# Email verification code (for DEBUG mode)
EMAIL_VERIFY_ADMIN_CODE=000000

# JWT Token Lifetime (minutes)
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1440

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://frontend:3000
CORS_ALLOW_CREDENTIALS=True

# Redis
REDIS_URL=redis://redis:6379/0

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@bookly.com

# Maps & Geocoding
YANDEX_MAPS_API_KEY=
DADATA_API_KEY=

# ===========================================
# Nuxt Frontend
# ===========================================
NODE_ENV=production
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# API URLs
API_BASE_URL=http://backend:8000
NUXT_PUBLIC_API_BASE_URL=/api


# -------------------------------------------
# Celery
# -------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0