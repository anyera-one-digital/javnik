# Скопируйте нужные строки в backend/.env (именно .env — его читает Django в Docker).
# После правок: docker compose restart backend

# --- T-Bank (Т-Касса), оплата Pro ---
# Личный кабинет: https://business.tbank.ru → Интернет-эквайринг
# Документация: https://developer.tbank.ru/eacq/api

TBANK_TERMINAL_KEY=ваш_терминал
TBANK_PASSWORD=ваш_пароль_терминала

# Тестовый API (терминалы *DEMO, TinkoffBankTest):
TBANK_API_URL=https://rest-api-test.tinkoff.ru/v2
# Боевой API:
# TBANK_API_URL=https://securepay.tinkoff.ru/v2

FRONTEND_BASE_URL=http://localhost:4000
API_PUBLIC_BASE_URL=http://localhost:8000

# Для продакшена с публичным доменом:
# API_PUBLIC_BASE_URL=https://api.yourdomain.com
# или TBANK_NOTIFICATION_URL=https://api.yourdomain.com/api/auth/payments/tbank/notification/
